#include <ESP8266WiFi.h>
#include <ESP8266WebServer.h>
#include <Wire.h>

// ---------------- WIFI ACCESS POINT SETTINGS ----------------
const char* ssid = "Wemos_Control";
const char* password = "12345678";

// ---------------- I2C SETTINGS ----------------
#define SLAVE_ADDRESS 0x08

// Wemos D1 UNO-style I2C pins:
// D14 = SDA
// D15 = SCL

ESP8266WebServer server(80);

// Must match Maker UNO struct exactly
struct __attribute__((packed)) PackagedData {
  float currentTemp;
  float potVoltage;
  int16_t distanceCm;
  uint8_t isAlertState;
};

PackagedData incomingData = {0.0, 0.0, 0, 0};

String actionStatus = "System Idle";
String i2cStatus = "Waiting for data";

// ---------------- FETCH DATA FROM MAKER UNO ----------------
void fetchTelemetry() {
  Wire.requestFrom(SLAVE_ADDRESS, sizeof(PackagedData));

  if (Wire.available() >= (int)sizeof(PackagedData)) {
    uint8_t* ptr = (uint8_t*)&incomingData;

    for (size_t i = 0; i < sizeof(PackagedData); i++) {
      ptr[i] = Wire.read();
    }

    i2cStatus = "Active";
  } else {
    i2cStatus = "No data";
  }

  while (Wire.available()) {
    Wire.read();
  }
}

// ---------------- SEND COMMAND TO MAKER UNO ----------------
void sendI2CCommand(uint8_t commandByte) {
  Wire.beginTransmission(SLAVE_ADDRESS);
  Wire.write(commandByte);

  byte result = Wire.endTransmission();

  if (result == 0) {
    i2cStatus = "Command sent";
  } else {
    i2cStatus = "I2C error";
  }
}

// ---------------- WEBPAGE ----------------
void handleRoot() {
  fetchTelemetry();

  String page = "";

  page += "<!DOCTYPE html>";
  page += "<html>";
  page += "<head>";
  page += "<meta name='viewport' content='width=device-width, initial-scale=1'>";
  page += "<title>Control Dashboard</title>";

  page += "<style>";
  page += "body{font-family:Arial,sans-serif;text-align:center;background:#f4f6f9;padding:20px;color:#333;}";
  page += ".card{background:white;padding:25px;margin:auto;max-width:460px;border-radius:15px;box-shadow:0 4px 15px rgba(0,0,0,0.1);}";
  page += "h1{color:#2c3e50;margin-bottom:5px;}";
  page += "p{color:#7f8c8d;}";
  page += ".status-banner{padding:12px;border-radius:8px;font-weight:bold;font-size:18px;margin:15px 0;}";
  page += ".secure{background:#d4edda;color:#155724;}";
  page += ".alert{background:#f8d7da;color:#721c24;animation:blink 1s infinite;}";
  page += ".grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:20px 0;}";
  page += ".grid-box{background:#f8f9fa;padding:15px;border-radius:8px;border:1px solid #e9ecef;}";
  page += ".grid-box b{font-size:14px;color:#7f8c8d;display:block;margin-bottom:5px;}";
  page += ".grid-box span{font-size:20px;font-weight:bold;color:#2c3e50;}";
  page += "button{width:100%;padding:14px;margin:8px 0;font-size:16px;font-weight:bold;border:none;border-radius:8px;cursor:pointer;transition:0.2s;}";
  page += ".btn-alarm-on{background:#e74c3c;color:white;}";
  page += ".btn-alarm-off{background:#3498db;color:white;}";
  page += ".btn-alarm-on:hover{background:#c0392b;}";
  page += ".btn-alarm-off:hover{background:#2980b9;}";
  page += ".log{margin-top:15px;background:#eef2f3;padding:12px;border-radius:8px;font-size:14px;border-left:5px solid #34495e;}";
  page += ".wifi{margin-top:15px;background:#e8f5e9;padding:12px;border-radius:8px;font-size:14px;}";
  page += "@keyframes blink{0%{opacity:1;}50%{opacity:0.6;}100%{opacity:1;}}";
  page += "</style>";

  page += "</head>";
  page += "<body>";

  page += "<div class='card'>";
  page += "<h1>System Framework</h1>";
  page += "<p style='margin-top:0;'>I2C Wireless Control Node</p>";

  if (incomingData.isAlertState) {
    page += "<div class='status-banner alert'>SYSTEM STATE: DANGER ALERT</div>";
  } else {
    page += "<div class='status-banner secure'>SYSTEM STATE: SECURE</div>";
  }

  page += "<div class='grid'>";

  page += "<div class='grid-box'><b>Temperature</b><span>";
  page += String(incomingData.currentTemp, 1);
  page += " &deg;C</span></div>";

  page += "<div class='grid-box'><b>Pot Voltage</b><span>";
  page += String(incomingData.potVoltage, 1);
  page += " V</span></div>";

  page += "<div class='grid-box'><b>Distance</b><span>";
  if (incomingData.distanceCm > 0) {
    page += String(incomingData.distanceCm);
    page += " cm";
  } else {
    page += "---";
  }
  page += "</span></div>";

  page += "<div class='grid-box'><b>I2C Connection</b><span>";
  page += i2cStatus;
  page += "</span></div>";

  page += "</div>";

  page += "<h3>Alarm Overrides</h3>";

  page += "<a href='/alarm_on'><button class='btn-alarm-on'>Force Trigger Alarm</button></a>";
  page += "<a href='/alarm_off'><button class='btn-alarm-off'>Force Clear Alarm</button></a>";

  page += "<div class='log'><b>Last Executed Command:</b><br>";
  page += actionStatus;
  page += "</div>";

  page += "<div class='wifi'><b>WiFi Network:</b><br>";
  page += ssid;
  page += "<br><br><b>Dashboard Link:</b><br>";
  page += "http://192.168.4.1";
  page += "</div>";

  page += "</div>";
  page += "</body>";
  page += "</html>";

  server.send(200, "text/html", page);
}

// ---------------- WEB ROUTES ----------------
void handleAlarmOn() {
  sendI2CCommand(0x03);
  actionStatus = "Dispatched: Manual Emergency Alarm ON [0x03]";
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleAlarmOff() {
  sendI2CCommand(0x04);
  actionStatus = "Dispatched: Manual Reset / Alarm OFF [0x04]";
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleNotFound() {
  server.send(404, "text/plain", "Page not found");
}

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(115200);
  delay(1000);

  // Start I2C as master
  // IMPORTANT: SDA first, SCL second
  Wire.begin(D14, D15); // D14 = SDA, D15 = SCL

  // Create WiFi network from Wemos itself
  WiFi.mode(WIFI_AP);
  WiFi.softAP(ssid, password);

  Serial.println();
  Serial.println("Wemos Access Point Started");
  Serial.print("WiFi Name: ");
  Serial.println(ssid);
  Serial.print("Password: ");
  Serial.println(password);
  Serial.print("Dashboard Link: http://");
  Serial.println(WiFi.softAPIP());

  server.on("/", handleRoot);
  server.on("/alarm_on", handleAlarmOn);
  server.on("/alarm_off", handleAlarmOff);
  server.onNotFound(handleNotFound);

  server.begin();

  Serial.println("Web server started");
}

// ---------------- LOOP ----------------
void loop() {
  server.handleClient();
}
